    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Run / Debug Local Catalog API",
            "request": "launch",
            "mainClass": "com.batistell.catalogapi.CatalogApiApplication",
            "projectName": "catalog-api",
            "env": {
                "PORT": "8090",
                "URI": "mongodb://localhost:27017",
                "USER": "admin",
                "PASSWORD": "admin"
            }
        },
        {
            "type": "java",
            "name": "Attach to Maven Remote",
            "request": "attach",
            "hostName": "localhost",
            "port": 5005
        }
    ]
}